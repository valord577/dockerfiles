#!/usr/bin/env sh
set -e

DIR=$(cd "$(dirname "${0}")"; pwd)

TARGET="x86_64-w64-mingw32"; _prev_arg=""
for arg in "$@"; do
  if [ "$prev_arg" = "-target" ]; then
    TARGET="$arg"; break
  fi
  prev_arg="$arg"
done


clang \
  --start-no-unused-arguments \
  -resource-dir=$(realpath $DIR/../lib/clang/*) \
  -rtlib=compiler-rt -unwindlib=libunwind -stdlib=libc++ -fuse-ld=lld \
  --sysroot=$(realpath $DIR/../$TARGET) \
  --end-no-unused-arguments \
  $@
