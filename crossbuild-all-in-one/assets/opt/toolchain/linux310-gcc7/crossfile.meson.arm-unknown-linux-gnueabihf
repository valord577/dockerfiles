[constants]
prefix = ''
ccache = []
triple = 'arm-unknown-linux-gnueabihf'
sys_root = '@DIRNAME@' / triple
gcc_root = '@DIRNAME@' / triple / 'usr'
ccflags = ['--target='+triple, '--gcc-toolchain='+gcc_root, '--sysroot='+sys_root, '-march=armv7-a', '-mfpu=neon-vfpv4', '-mfloat-abi=hard']
ldflags = ['-fuse-ld=lld', '--sysroot='+sys_root]

[host_machine]
system = 'linux'
kernel = 'linux'
cpu_family = 'arm'
cpu = 'arm'
endian = 'little'

[properties]
needs_exe_wrapper = false
cmake_defaults    = false
cmake_toolchain_file = '@DIRNAME@/crossfile.cmake.' + triple

[binaries]
c   = ccache + [prefix / 'clang']   + ccflags
cpp = ccache + [prefix / 'clang++'] + ccflags
ar = prefix / 'llvm-ar'
as = prefix / 'llvm-as'
nm = prefix / 'llvm-nm'
objcopy = prefix / 'llvm-objcopy'
strip   = prefix / 'llvm-strip'
ranlib  = prefix / 'llvm-ranlib'
pkg-config = '@DIRNAME@/pkgconf-wrapper.' + triple
cmake = 'cmake'

[built-in options]
c_link_args   = ldflags
cpp_link_args = ldflags
