[base]
name=CentOS-$releasever - Base
baseurl=http://repo.huaweicloud.com/centos/7/os/$basearch/
gpgcheck=0

[updates]
name=CentOS-$releasever - Updates
baseurl=http://repo.huaweicloud.com/centos/7/updates/$basearch/
gpgcheck=0

[extras]
name=CentOS-$releasever - Extras
baseurl=http://repo.huaweicloud.com/centos/7/extras/$basearch/
gpgcheck=0
enabled=1

[sclo-rh]
name=CentOS-$releasever - SCLo rh
baseurl=http://repo.huaweicloud.com/centos/7/sclo/$basearch/rh/
gpgcheck=0
enabled=1

